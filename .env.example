# System Admin (bootstrap - creates admin user on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=efipoker
POSTGRES_USER=efipoker
POSTGRES_PASSWORD=changeme

# App
SERVER_PORT=8080
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Registration (set to false to disable public user registration)
REGISTRATION_ENABLED=true

# JWT
JWT_SECRET=change-me-to-random-64-char-string
JWT_EXPIRATION=86400

# Auth0 (optional, for OAuth2 admin login - set AUTH0_ENABLED=true to activate)
AUTH0_ENABLED=false
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
