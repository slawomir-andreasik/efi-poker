# System Admin (bootstrap - creates admin user on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=efipoker
POSTGRES_USER=efipoker
POSTGRES_PASSWORD=changeme

# App
SERVER_PORT=8080
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Registration (set to false to disable public user registration)
REGISTRATION_ENABLED=true

# JWT
JWT_SECRET=change-me-to-random-64-char-string
JWT_EXPIRATION=86400

# Auth0 (optional, for OAuth2 admin login - set AUTH0_ENABLED=true to activate)
AUTH0_ENABLED=false
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# LDAP (optional, for corporate LDAP authentication - set LDAP_ENABLED=true to activate)
# Start local LDAP: docker compose -f compose.dev.yaml --profile ldap up -d ldap
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_USERS_DN=ou=users
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=adminpassword
LDAP_USER_FILTER=(&(uid={0})(description=userInternal)(description=active))
LDAP_UID_ATTRIBUTE=uid
LDAP_MAIL_ATTRIBUTE=mail
LDAP_ADMIN_GROUP=efipoker-admins
