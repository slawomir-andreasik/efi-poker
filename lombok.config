# Stop scanning parent directories for lombok.config
config.stopBubbling = true

# JPA entities use manual equals/hashCode (Hibernate proxy-safe pattern)
lombok.equalsAndHashCode.flagUsage = error

# No experimental Lombok features - use stable API only
lombok.experimental.flagUsage = error

# Mark generated code so JaCoCo excludes it from coverage
lombok.addLombokGeneratedAnnotation = true

# Copy Spring qualifier/value annotations to generated constructors
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
